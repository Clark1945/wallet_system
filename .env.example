# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# SBPS (SoftBank Payment Service)
PAYMENT_MERCHANT_ID=
PAYMENT_SERVICE_ID=
PAYMENT_HASH_KEY=

# Withdrawal webhook shared secret (wallet_system ↔ mock-bank)
WITHDRAW_WEBHOOK_SECRET=

# RabbitMQ (wallet-service publishes → email-service consumes)
RABBITMQ_USER=admin
RABBITMQ_PASS=

# Internal service secret (wallet-service ↔ payment-service)
INTERNAL_SERVICE_SECRET=ClarkIsCurrentlyTest@123456789

# Email (optional — defaults to Gmail SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# --- Local development only (not needed for docker compose up) ---
# DB credentials (docker compose uses hardcoded postgres/postgres internally)
DB_URL=jdbc:postgresql://localhost:5432/wallet_db
DB_USERNAME=postgres
DB_PASSWORD=postgres
