    {
      "id": 32,
      "title": "5xx Error Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 36, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "wallet-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (application) (rate(http_server_requests_seconds_count{application=~\"$application\", status=~\"5..\"}[1m]))",
          "legendFormat": "{{application}} 5xx"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
