      }
    },

    {
      "id": 14,
      "title": "JVM Threads",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 18, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "wallet-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "jvm_threads_live_threads{application=~\"$application\"}",
          "legendFormat": "{{application}} Live"
        },
        {
          "refId": "B",
          "expr": "jvm_threads_daemon_threads{application=~\"$application\"}",
          "legendFormat": "{{application}} Daemon"
        },
        {
          "refId": "C",
          "expr": "jvm_threads_peak_threads{application=~\"$application\"}",
          "legendFormat": "{{application}} Peak"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "palette-classic" },
