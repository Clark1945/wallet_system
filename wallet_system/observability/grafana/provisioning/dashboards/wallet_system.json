      }
    },

    {
      "id": 33,
      "title": "Average Response Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 44, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "wallet-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (application, uri) (rate(http_server_requests_seconds_sum{application=~\"$application\", uri!~\"/actuator.*\"}[1m])) / sum by (application, uri) (rate(http_server_requests_seconds_count{application=~\"$application\", uri!~\"/actuator.*\"}[1m]))",
          "legendFormat": "{{application}} {{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 5,
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },

