    {
      "id": 10,
      "type": "row",
      "title": "JVM — $application",
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 },
      "collapsed": false,
      "repeat": null
    },

    {
      "id": 11,
      "title": "Heap Memory",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 10, "w": 16, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "wallet-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (application) (jvm_memory_used_bytes{area=\"heap\", application=~\"$application\"})",
          "legendFormat": "{{application}} Used"
        },
        {
          "refId": "B",
          "expr": "sum by (application) (jvm_memory_max_bytes{area=\"heap\", application=~\"$application\"})",
          "legendFormat": "{{application}} Max"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },

    {
      "id": 12,
      "title": "Heap Usage %",
      "type": "gauge",
      "gridPos": { "x": 16, "y": 10, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "wallet-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (application) (jvm_memory_used_bytes{area=\"heap\", application=~\"$application\"}) / sum by (application) (jvm_memory_max_bytes{area=\"heap\", application=~\"$application\"}) * 100",
          "legendFormat": "{{application}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },

    {
      "id": 13,
      "title": "Non-Heap Memory",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 8 },
