{
  "title": "Wallet System — All Services",
  "uid": "wallet-system-overview",
  "description": "Multi-service monitoring: wallet-system, payment-service, email-service, mock-bank + infrastructure",
  "tags": ["wallet", "jvm", "spring-boot", "microservices"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "graphTooltip": 1,
  "editable": true,
  "annotations": { "list": [] },
  "links": [],

  "templating": {
    "list": [
      {
        "name": "application",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "wallet-prometheus" },
        "query": { "query": "label_values(process_cpu_usage, application)", "refId": "A" },
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "sort": 1,
        "current": {}
      }
    ]
  },

  "panels": [

    {
      "id": 1,
      "type": "row",
      "title": "Service Health",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 2,
      "title": "wallet-system",
      "type": "stat",
      "gridPos": { "x": 0, "y": 1, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "wallet-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=\"wallet-system\"}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "text": { "titleSize": 14, "valueSize": 32 }
      }
    },

